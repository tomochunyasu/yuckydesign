<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>車両・部品管理システム | Yucky Design</title>
<style>
:root {
  --brand: #1447E6;
  --brand-light: #EEF3FF;
  --ink: #111318;
  --ink-soft: #3A3D47;
  --ink-muted: #6B7280;
  --white: #FFFFFF;
  --border: rgba(0,0,0,0.1);
  --green: #00B050;
  --yellow: #F59E0B;
  --red: #EF4444;
  --orange: #FF8800;
  --shadow: 0 2px 16px rgba(0,0,0,0.08);
  --shadow-strong: 0 8px 40px rgba(0,0,0,0.14);
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Hiragino Sans', 'Noto Sans JP', sans-serif; background: #F0F2F5; color: var(--ink); -webkit-font-smoothing: antialiased; }
a { color: inherit; text-decoration: none; }

/* HEADER */
.header {
  background: var(--ink); color: var(--white);
  padding: 0 24px; height: 56px;
  display: flex; align-items: center; justify-content: space-between;
  position: sticky; top: 0; z-index: 100;
  box-shadow: 0 2px 8px rgba(0,0,0,0.2);
}
.header-title { font-weight: 700; font-size: 1rem; display: flex; align-items: center; gap: 10px; }
.header-title span { font-size: 1.2rem; }
.header-badge {
  font-size: 0.7rem; background: var(--brand); padding: 3px 10px;
  border-radius: 999px; font-weight: 700;
}
.header-right { font-size: 0.8rem; color: rgba(255,255,255,0.5); }

/* TABS */
.tabs {
  background: var(--white); border-bottom: 1.5px solid var(--border);
  display: flex; padding: 0 16px; overflow-x: auto;
  position: sticky; top: 56px; z-index: 99;
}
.tab {
  padding: 14px 20px; font-size: 0.875rem; font-weight: 700;
  color: var(--ink-muted); cursor: pointer; white-space: nowrap;
  border-bottom: 2.5px solid transparent; transition: all 0.15s;
  display: flex; align-items: center; gap: 6px;
}
.tab:hover { color: var(--brand); }
.tab.active { color: var(--brand); border-bottom-color: var(--brand); }

/* MAIN */
.main { max-width: 1100px; margin: 0 auto; padding: 24px 16px; }
.tab-content { display: none; }
.tab-content.active { display: block; }

/* CARDS ROW */
.stats-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 12px; margin-bottom: 24px; }
.stat-card {
  background: var(--white); border-radius: 14px;
  padding: 1.25rem 1.5rem; box-shadow: var(--shadow);
}
.stat-label { font-size: 0.78rem; color: var(--ink-muted); font-weight: 600; margin-bottom: 0.5rem; }
.stat-num { font-size: 2rem; font-weight: 900; color: var(--ink); line-height: 1; }
.stat-num.green { color: var(--green); }
.stat-num.yellow { color: var(--yellow); }
.stat-num.red { color: var(--red); }

/* SECTION */
.section-card {
  background: var(--white); border-radius: 16px;
  box-shadow: var(--shadow); margin-bottom: 20px; overflow: hidden;
}
.section-head {
  padding: 16px 20px; border-bottom: 1.5px solid var(--border);
  display: flex; align-items: center; justify-content: space-between;
}
.section-title { font-weight: 700; font-size: 0.95rem; display: flex; align-items: center; gap: 8px; }
.section-body { padding: 16px 20px; }

/* ALERT ITEMS */
.alert-list { display: flex; flex-direction: column; gap: 8px; }
.alert-item {
  display: flex; align-items: center; gap: 12px;
  padding: 10px 14px; border-radius: 10px;
  font-size: 0.875rem;
}
.alert-item.red { background: #FEF2F2; border: 1px solid #FECACA; }
.alert-item.yellow { background: #FFFBEB; border: 1px solid #FDE68A; }
.alert-item.green { background: #F0FDF4; border: 1px solid #BBF7D0; }
.alert-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
.alert-dot.red { background: var(--red); }
.alert-dot.yellow { background: var(--yellow); }
.alert-dot.green { background: var(--green); }
.alert-text { flex: 1; }
.alert-date { font-size: 0.78rem; color: var(--ink-muted); white-space: nowrap; }

/* TABLE */
.table-wrap { overflow-x: auto; }
table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
th {
  text-align: left; padding: 10px 14px;
  background: #F8F9FA; color: var(--ink-muted);
  font-size: 0.75rem; font-weight: 700; letter-spacing: 0.05em;
  border-bottom: 1.5px solid var(--border);
}
td { padding: 12px 14px; border-bottom: 1px solid var(--border); vertical-align: middle; }
tr:last-child td { border-bottom: none; }
tr:hover td { background: #FAFAFA; }

/* STATUS BADGE */
.badge {
  display: inline-flex; align-items: center; gap: 4px;
  font-size: 0.72rem; font-weight: 700;
  padding: 3px 10px; border-radius: 999px;
}
.badge.green { background: #DCFCE7; color: #166534; }
.badge.yellow { background: #FEF9C3; color: #854D0E; }
.badge.red { background: #FEE2E2; color: #991B1B; }
.badge.blue { background: var(--brand-light); color: var(--brand); }
.badge.gray { background: #F3F4F6; color: var(--ink-muted); }

/* BTN */
.btn {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 8px 16px; border-radius: 8px; font-size: 0.85rem; font-weight: 700;
  cursor: pointer; border: none; transition: all 0.15s;
}
.btn-primary { background: var(--brand); color: var(--white); }
.btn-primary:hover { background: #0F37C9; }
.btn-sm { padding: 5px 10px; font-size: 0.75rem; border-radius: 6px; }
.btn-ghost { background: transparent; color: var(--ink-muted); border: 1.5px solid var(--border); }
.btn-ghost:hover { background: #F3F4F6; color: var(--ink); }
.btn-danger { background: #FEE2E2; color: var(--red); }
.btn-danger:hover { background: #FECACA; }

/* MODAL */
.modal-overlay {
  display: none; position: fixed; inset: 0;
  background: rgba(0,0,0,0.45); z-index: 200;
  align-items: center; justify-content: center; padding: 16px;
}
.modal-overlay.open { display: flex; }
.modal {
  background: var(--white); border-radius: 18px;
  padding: 28px; width: 100%; max-width: 520px;
  box-shadow: var(--shadow-strong); max-height: 90vh; overflow-y: auto;
}
.modal-title { font-weight: 700; font-size: 1.05rem; margin-bottom: 20px; }
.form-row { margin-bottom: 14px; }
.form-row label { display: block; font-size: 0.82rem; font-weight: 700; color: var(--ink-soft); margin-bottom: 5px; }
.form-row input, .form-row select, .form-row textarea {
  width: 100%; padding: 9px 12px;
  border: 1.5px solid #CBD5E0; border-radius: 8px;
  font-size: 0.9rem; font-family: inherit; color: var(--ink);
}
.form-row input:focus, .form-row select:focus, .form-row textarea:focus {
  outline: none; border-color: var(--brand);
  box-shadow: 0 0 0 3px rgba(20,71,230,0.1);
}
.form-row textarea { min-height: 80px; resize: vertical; }
.modal-footer { display: flex; gap: 10px; justify-content: flex-end; margin-top: 20px; }

/* EMPTY */
.empty { text-align: center; padding: 40px 20px; color: var(--ink-muted); font-size: 0.9rem; }
.empty-icon { font-size: 2.5rem; margin-bottom: 10px; }

/* FILTER ROW */
.filter-row { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin-bottom: 16px; }
.filter-row select { padding: 7px 12px; border: 1.5px solid var(--border); border-radius: 8px; font-size: 0.85rem; font-family: inherit; }
.filter-row input { padding: 7px 12px; border: 1.5px solid var(--border); border-radius: 8px; font-size: 0.85rem; font-family: inherit; }

/* VEHICLE CARD GRID (mobile) */
.vehicle-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 12px; }
.vehicle-card {
  background: var(--white); border-radius: 14px;
  border: 1.5px solid var(--border); padding: 16px;
  box-shadow: var(--shadow); cursor: pointer;
  transition: transform 0.15s, box-shadow 0.15s;
}
.vehicle-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-strong); }
.vehicle-card-head { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 10px; }
.vehicle-name { font-weight: 700; font-size: 1rem; }
.vehicle-plate { font-size: 0.8rem; color: var(--ink-muted); margin-top: 2px; }
.vehicle-card-info { font-size: 0.82rem; color: var(--ink-soft); margin-bottom: 10px; }
.vehicle-card-info span { margin-right: 12px; }
.vehicle-card-foot { display: flex; align-items: center; justify-content: space-between; }
.inspection-date { font-size: 0.8rem; }

/* RESPONSIVE */
@media (max-width: 600px) {
  .header { padding: 0 14px; }
  .main { padding: 16px 10px; }
  .section-head { padding: 12px 14px; }
  .section-body { padding: 12px 14px; }
  td, th { padding: 9px 10px; }
  .tab { padding: 12px 14px; font-size: 0.8rem; }
  .stats-row { grid-template-columns: 1fr 1fr; }
}
</style>
</head>
<body>

<!-- HEADER -->
<div class="header">
  <div class="header-title">
    <span>🚗</span> 車両・部品管理システム
    <span class="header-badge">DEMO</span>
  </div>
  <div class="header-right">Powered by Yucky Design</div>
</div>

<!-- TABS -->
<div class="tabs">
  <div class="tab active" onclick="switchTab('dashboard')">📊 ダッシュボード</div>
  <div class="tab" onclick="switchTab('vehicles')">🚗 車両管理</div>
  <div class="tab" onclick="switchTab('maintenance')">🔧 整備履歴</div>
  <div class="tab" onclick="switchTab('parts')">⚙️ 部品管理</div>
</div>

<div class="main">

  <!-- DASHBOARD -->
  <div class="tab-content active" id="tab-dashboard">
    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-label">🚗 登録車両数</div>
        <div class="stat-num" id="stat-total">0</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">✅ 正常</div>
        <div class="stat-num green" id="stat-ok">0</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">⚠️ 要注意</div>
        <div class="stat-num yellow" id="stat-warn">0</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">🔴 期限切れ</div>
        <div class="stat-num red" id="stat-over">0</div>
      </div>
    </div>

    <div class="section-card">
      <div class="section-head">
        <div class="section-title">🔔 点検アラート</div>
      </div>
      <div class="section-body">
        <div class="alert-list" id="alert-list">
          <div class="empty"><div class="empty-icon">✅</div>点検が必要な車両はありません</div>
        </div>
      </div>
    </div>

    <div class="section-card">
      <div class="section-head">
        <div class="section-title">🔧 最近の整備記録</div>
      </div>
      <div class="section-body">
        <div class="table-wrap">
          <table>
            <thead><tr><th>日付</th><th>車両</th><th>作業内容</th><th>走行距離</th></tr></thead>
            <tbody id="recent-maintenance"></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- VEHICLES -->
  <div class="tab-content" id="tab-vehicles">
    <div class="section-card">
      <div class="section-head">
        <div class="section-title">🚗 車両一覧</div>
        <button class="btn btn-primary" onclick="openVehicleModal()">＋ 車両を追加</button>
      </div>
      <div class="section-body">
        <div class="vehicle-grid" id="vehicle-grid"></div>
      </div>
    </div>
  </div>

  <!-- MAINTENANCE -->
  <div class="tab-content" id="tab-maintenance">
    <div class="section-card">
      <div class="section-head">
        <div class="section-title">🔧 整備履歴</div>
        <button class="btn btn-primary" onclick="openMaintenanceModal()">＋ 整備記録を追加</button>
      </div>
      <div class="section-body">
        <div class="filter-row">
          <select id="filter-maint-vehicle" onchange="renderMaintenance()">
            <option value="">すべての車両</option>
          </select>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr><th>日付</th><th>車両</th><th>作業種別</th><th>作業内容</th><th>走行距離</th><th>費用</th><th>次回予定</th><th></th></tr>
            </thead>
            <tbody id="maintenance-tbody"></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- PARTS -->
  <div class="tab-content" id="tab-parts">
    <div class="section-card">
      <div class="section-head">
        <div class="section-title">⚙️ 部品交換記録</div>
        <button class="btn btn-primary" onclick="openPartsModal()">＋ 部品記録を追加</button>
      </div>
      <div class="section-body">
        <div class="filter-row">
          <select id="filter-parts-vehicle" onchange="renderParts()">
            <option value="">すべての車両</option>
          </select>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr><th>交換日</th><th>車両</th><th>部品名</th><th>交換時距離</th><th>次回交換距離</th><th>費用</th><th>メモ</th><th></th></tr>
            </thead>
            <tbody id="parts-tbody"></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

</div>

<!-- MODAL: 車両 -->
<div class="modal-overlay" id="modal-vehicle">
  <div class="modal">
    <div class="modal-title" id="modal-vehicle-title">車両を追加</div>
    <input type="hidden" id="vehicle-edit-id">
    <div class="form-row"><label>車両名・車号 <span style="color:red">*</span></label><input id="v-name" placeholder="例: 1号車 / トヨタ ハイエース"></div>
    <div class="form-row"><label>ナンバープレート</label><input id="v-plate" placeholder="例: 品川 300 あ 1234"></div>
    <div class="form-row"><label>メーカー・車種</label><input id="v-maker" placeholder="例: トヨタ ハイエース"></div>
    <div class="form-row"><label>年式</label><input id="v-year" type="number" placeholder="例: 2020"></div>
    <div class="form-row"><label>現在の走行距離（km）</label><input id="v-mileage" type="number" placeholder="例: 45000"></div>
    <div class="form-row"><label>次回車検日 <span style="color:red">*</span></label><input id="v-inspection" type="date"></div>
    <div class="form-row"><label>メモ</label><textarea id="v-notes" placeholder="担当者・保管場所など"></textarea></div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-vehicle')">キャンセル</button>
      <button class="btn btn-primary" onclick="saveVehicle()">保存する</button>
    </div>
  </div>
</div>

<!-- MODAL: 整備 -->
<div class="modal-overlay" id="modal-maintenance">
  <div class="modal">
    <div class="modal-title">整備記録を追加</div>
    <input type="hidden" id="maint-edit-id">
    <div class="form-row"><label>車両 <span style="color:red">*</span></label><select id="m-vehicle"></select></div>
    <div class="form-row"><label>整備日 <span style="color:red">*</span></label><input id="m-date" type="date"></div>
    <div class="form-row">
      <label>作業種別</label>
      <select id="m-type">
        <option>定期点検</option>
        <option>車検</option>
        <option>エンジンオイル交換</option>
        <option>タイヤ交換</option>
        <option>ブレーキ整備</option>
        <option>修理・不具合対応</option>
        <option>その他</option>
      </select>
    </div>
    <div class="form-row"><label>作業内容 <span style="color:red">*</span></label><textarea id="m-desc" placeholder="実施した作業の詳細"></textarea></div>
    <div class="form-row"><label>走行距離（km）</label><input id="m-mileage" type="number" placeholder="例: 50000"></div>
    <div class="form-row"><label>費用（円）</label><input id="m-cost" type="number" placeholder="例: 35000"></div>
    <div class="form-row"><label>担当者・整備工場</label><input id="m-worker" placeholder="例: ○○自動車"></div>
    <div class="form-row"><label>次回整備予定日</label><input id="m-next" type="date"></div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-maintenance')">キャンセル</button>
      <button class="btn btn-primary" onclick="saveMaintenance()">保存する</button>
    </div>
  </div>
</div>

<!-- MODAL: 部品 -->
<div class="modal-overlay" id="modal-parts">
  <div class="modal">
    <div class="modal-title">部品交換記録を追加</div>
    <input type="hidden" id="parts-edit-id">
    <div class="form-row"><label>車両 <span style="color:red">*</span></label><select id="p-vehicle"></select></div>
    <div class="form-row"><label>交換日 <span style="color:red">*</span></label><input id="p-date" type="date"></div>
    <div class="form-row"><label>部品名 <span style="color:red">*</span></label><input id="p-name" placeholder="例: エンジンオイル / エアフィルター / タイヤ（前輪）"></div>
    <div class="form-row"><label>部品番号・品番</label><input id="p-number" placeholder="例: 08880-10705"></div>
    <div class="form-row"><label>交換時の走行距離（km）</label><input id="p-mileage" type="number" placeholder="例: 50000"></div>
    <div class="form-row"><label>次回交換目安距離（km）</label><input id="p-next-mileage" type="number" placeholder="例: 55000"></div>
    <div class="form-row"><label>費用（円）</label><input id="p-cost" type="number" placeholder="例: 8000"></div>
    <div class="form-row"><label>メモ</label><textarea id="p-notes" placeholder="メーカー・グレードなど"></textarea></div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-parts')">キャンセル</button>
      <button class="btn btn-primary" onclick="saveParts()">保存する</button>
    </div>
  </div>
</div>

<script>
// ─── DATA ───
let db = {
  vehicles: [],
  maintenance: [],
  parts: []
};

function loadDB() {
  const saved = localStorage.getItem('vehicle_mgmt_db');
  if (saved) {
    db = JSON.parse(saved);
  } else {
    // サンプルデータ
    const today = new Date();
    const fmt = d => d.toISOString().slice(0,10);
    const addDays = (d, n) => { const r = new Date(d); r.setDate(r.getDate()+n); return r; };

    db.vehicles = [
      { id:'v1', name:'1号車', plate:'品川 300 あ 1234', maker:'トヨタ ハイエース', year:2020, mileage:52300, inspection: fmt(addDays(today, 15)), notes:'倉庫保管' },
      { id:'v2', name:'2号車', plate:'品川 400 い 5678', maker:'日産 キャラバン', year:2019, mileage:78000, inspection: fmt(addDays(today, -5)), notes:'' },
      { id:'v3', name:'3号車', plate:'横浜 500 う 9012', maker:'三菱 ふそう キャンター', year:2021, mileage:31000, inspection: fmt(addDays(today, 120)), notes:'Aドライバー担当' },
    ];
    db.maintenance = [
      { id:'m1', vehicleId:'v1', date: fmt(addDays(today,-30)), type:'エンジンオイル交換', desc:'オイル・フィルター交換', mileage:50000, cost:8000, worker:'○○自動車', next: fmt(addDays(today,60)) },
      { id:'m2', vehicleId:'v2', date: fmt(addDays(today,-10)), type:'定期点検', desc:'6ヶ月点検・各部確認', mileage:77500, cost:25000, worker:'日産ディーラー', next:'' },
      { id:'m3', vehicleId:'v3', date: fmt(addDays(today,-5)), type:'タイヤ交換', desc:'前輪タイヤ2本交換', mileage:30800, cost:32000, worker:'タイヤ館', next:'' },
    ];
    db.parts = [
      { id:'p1', vehicleId:'v1', date: fmt(addDays(today,-30)), name:'エンジンオイル', number:'5W-30', mileage:50000, nextMileage:55000, cost:4500, notes:'全合成油' },
      { id:'p2', vehicleId:'v2', date: fmt(addDays(today,-90)), name:'エアフィルター', number:'', mileage:75000, nextMileage:85000, cost:3200, notes:'' },
      { id:'p3', vehicleId:'v3', date: fmt(addDays(today,-5)), name:'タイヤ（前輪）', number:'195/80R15', mileage:30800, nextMileage:80800, cost:32000, notes:'ブリヂストン' },
    ];
    saveDB();
  }
}
function saveDB() { localStorage.setItem('vehicle_mgmt_db', JSON.stringify(db)); }
function uid() { return 'id_' + Date.now() + '_' + Math.random().toString(36).slice(2,7); }

// ─── STATUS ───
function inspectionStatus(dateStr) {
  if (!dateStr) return { label:'未設定', cls:'gray', days: null };
  const today = new Date(); today.setHours(0,0,0,0);
  const d = new Date(dateStr);
  const diff = Math.ceil((d - today) / 86400000);
  if (diff < 0) return { label:`${Math.abs(diff)}日超過`, cls:'red', days: diff };
  if (diff <= 30) return { label:`残${diff}日`, cls:'yellow', days: diff };
  return { label:`残${diff}日`, cls:'green', days: diff };
}

// ─── TABS ───
function switchTab(name) {
  document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(el => el.classList.remove('active'));
  document.getElementById('tab-'+name).classList.add('active');
  event.target.closest('.tab').classList.add('active');
  render();
}

// ─── RENDER ───
function render() {
  renderDashboard();
  renderVehicles();
  renderMaintenance();
  renderParts();
  updateVehicleSelects();
}

function renderDashboard() {
  const total = db.vehicles.length;
  let ok=0, warn=0, over=0;
  const alerts = [];
  db.vehicles.forEach(v => {
    const st = inspectionStatus(v.inspection);
    if (st.cls === 'green') ok++;
    else if (st.cls === 'yellow') { warn++; alerts.push({v, st}); }
    else if (st.cls === 'red') { over++; alerts.push({v, st}); }
    else ok++;
  });
  document.getElementById('stat-total').textContent = total;
  document.getElementById('stat-ok').textContent = ok;
  document.getElementById('stat-warn').textContent = warn;
  document.getElementById('stat-over').textContent = over;

  const alertList = document.getElementById('alert-list');
  if (alerts.length === 0) {
    alertList.innerHTML = '<div class="empty"><div class="empty-icon">✅</div>点検が必要な車両はありません</div>';
  } else {
    alerts.sort((a,b) => a.st.days - b.st.days);
    alertList.innerHTML = alerts.map(({v, st}) => `
      <div class="alert-item ${st.cls}">
        <div class="alert-dot ${st.cls}"></div>
        <div class="alert-text"><strong>${v.name}</strong>（${v.plate || '-'}）の車検 — <span style="font-weight:700">${st.label}</span></div>
        <div class="alert-date">${v.inspection}</div>
      </div>
    `).join('');
  }

  const recent = [...db.maintenance].sort((a,b)=>b.date.localeCompare(a.date)).slice(0,5);
  const tbody = document.getElementById('recent-maintenance');
  if (recent.length === 0) {
    tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;color:var(--ink-muted);padding:24px">記録がありません</td></tr>';
  } else {
    tbody.innerHTML = recent.map(m => {
      const v = db.vehicles.find(x=>x.id===m.vehicleId);
      return `<tr><td>${m.date}</td><td>${v ? v.name : '-'}</td><td>${m.type}<br><span style="font-size:0.78rem;color:var(--ink-muted)">${m.desc}</span></td><td>${m.mileage ? m.mileage.toLocaleString()+'km' : '-'}</td></tr>`;
    }).join('');
  }
}

function renderVehicles() {
  const grid = document.getElementById('vehicle-grid');
  if (db.vehicles.length === 0) {
    grid.innerHTML = '<div class="empty" style="grid-column:1/-1"><div class="empty-icon">🚗</div>車両が登録されていません<br><button class="btn btn-primary" style="margin-top:12px" onclick="openVehicleModal()">＋ 最初の車両を追加</button></div>';
    return;
  }
  grid.innerHTML = db.vehicles.map(v => {
    const st = inspectionStatus(v.inspection);
    return `
      <div class="vehicle-card">
        <div class="vehicle-card-head">
          <div>
            <div class="vehicle-name">🚗 ${v.name}</div>
            <div class="vehicle-plate">${v.plate || '（ナンバー未登録）'}</div>
          </div>
          <span class="badge ${st.cls}">${st.label}</span>
        </div>
        <div class="vehicle-card-info">
          <span>📅 ${v.year || '-'}年式</span>
          <span>🔢 ${v.mileage ? v.mileage.toLocaleString()+'km' : '-'}</span>
          ${v.maker ? `<span>🏭 ${v.maker}</span>` : ''}
        </div>
        <div class="vehicle-card-foot">
          <div class="inspection-date">🔍 次回車検: <strong>${v.inspection || '未設定'}</strong></div>
          <div style="display:flex;gap:6px">
            <button class="btn btn-ghost btn-sm" onclick="openVehicleModal('${v.id}')">編集</button>
            <button class="btn btn-danger btn-sm" onclick="deleteVehicle('${v.id}')">削除</button>
          </div>
        </div>
        ${v.notes ? `<div style="margin-top:8px;font-size:0.78rem;color:var(--ink-muted)">📝 ${v.notes}</div>` : ''}
      </div>
    `;
  }).join('');
}

function renderMaintenance() {
  const filter = document.getElementById('filter-maint-vehicle').value;
  let records = [...db.maintenance].sort((a,b)=>b.date.localeCompare(a.date));
  if (filter) records = records.filter(r=>r.vehicleId===filter);
  const tbody = document.getElementById('maintenance-tbody');
  if (records.length === 0) {
    tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;color:var(--ink-muted);padding:24px">整備記録がありません</td></tr>';
    return;
  }
  tbody.innerHTML = records.map(m => {
    const v = db.vehicles.find(x=>x.id===m.vehicleId);
    return `<tr>
      <td>${m.date}</td>
      <td>${v ? v.name : '-'}</td>
      <td><span class="badge blue">${m.type}</span></td>
      <td>${m.desc}</td>
      <td>${m.mileage ? m.mileage.toLocaleString()+'km' : '-'}</td>
      <td>${m.cost ? '¥'+m.cost.toLocaleString() : '-'}</td>
      <td>${m.next || '-'}</td>
      <td><button class="btn btn-danger btn-sm" onclick="deleteMaintenance('${m.id}')">削除</button></td>
    </tr>`;
  }).join('');
}

function renderParts() {
  const filter = document.getElementById('filter-parts-vehicle').value;
  let records = [...db.parts].sort((a,b)=>b.date.localeCompare(a.date));
  if (filter) records = records.filter(r=>r.vehicleId===filter);
  const tbody = document.getElementById('parts-tbody');
  if (records.length === 0) {
    tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;color:var(--ink-muted);padding:24px">部品記録がありません</td></tr>';
    return;
  }
  tbody.innerHTML = records.map(p => {
    const v = db.vehicles.find(x=>x.id===p.vehicleId);
    const needsReplacement = p.nextMileage && v && v.mileage >= p.nextMileage;
    const nearReplacement = p.nextMileage && v && (p.nextMileage - v.mileage) <= 3000 && !needsReplacement;
    return `<tr>
      <td>${p.date}</td>
      <td>${v ? v.name : '-'}</td>
      <td><strong>${p.name}</strong>${p.number ? `<br><span style="font-size:0.75rem;color:var(--ink-muted)">${p.number}</span>` : ''}</td>
      <td>${p.mileage ? p.mileage.toLocaleString()+'km' : '-'}</td>
      <td>${p.nextMileage ? `<span class="badge ${needsReplacement?'red':nearReplacement?'yellow':'green'}">${p.nextMileage.toLocaleString()}km</span>` : '-'}</td>
      <td>${p.cost ? '¥'+p.cost.toLocaleString() : '-'}</td>
      <td style="font-size:0.78rem;color:var(--ink-muted)">${p.notes || '-'}</td>
      <td><button class="btn btn-danger btn-sm" onclick="deletePart('${p.id}')">削除</button></td>
    </tr>`;
  }).join('');
}

function updateVehicleSelects() {
  const opts = '<option value="">（車両を選択）</option>' + db.vehicles.map(v=>`<option value="${v.id}">${v.name}</option>`).join('');
  const filterOpts = '<option value="">すべての車両</option>' + db.vehicles.map(v=>`<option value="${v.id}">${v.name}</option>`).join('');
  document.getElementById('m-vehicle').innerHTML = opts;
  document.getElementById('p-vehicle').innerHTML = opts;
  document.getElementById('filter-maint-vehicle').innerHTML = filterOpts;
  document.getElementById('filter-parts-vehicle').innerHTML = filterOpts;
}

// ─── MODAL ───
function openVehicleModal(id) {
  document.getElementById('vehicle-edit-id').value = id || '';
  const modal = document.getElementById('modal-vehicle');
  if (id) {
    const v = db.vehicles.find(x=>x.id===id);
    document.getElementById('modal-vehicle-title').textContent = '車両を編集';
    document.getElementById('v-name').value = v.name || '';
    document.getElementById('v-plate').value = v.plate || '';
    document.getElementById('v-maker').value = v.maker || '';
    document.getElementById('v-year').value = v.year || '';
    document.getElementById('v-mileage').value = v.mileage || '';
    document.getElementById('v-inspection').value = v.inspection || '';
    document.getElementById('v-notes').value = v.notes || '';
  } else {
    document.getElementById('modal-vehicle-title').textContent = '車両を追加';
    ['v-name','v-plate','v-maker','v-year','v-mileage','v-inspection','v-notes'].forEach(id=>document.getElementById(id).value='');
  }
  modal.classList.add('open');
}

function openMaintenanceModal() {
  document.getElementById('maint-edit-id').value = '';
  document.getElementById('m-date').value = new Date().toISOString().slice(0,10);
  ['m-desc','m-mileage','m-cost','m-worker','m-next'].forEach(id=>document.getElementById(id).value='');
  updateVehicleSelects();
  document.getElementById('modal-maintenance').classList.add('open');
}

function openPartsModal() {
  document.getElementById('parts-edit-id').value = '';
  document.getElementById('p-date').value = new Date().toISOString().slice(0,10);
  ['p-name','p-number','p-mileage','p-next-mileage','p-cost','p-notes'].forEach(id=>document.getElementById(id).value='');
  updateVehicleSelects();
  document.getElementById('modal-parts').classList.add('open');
}

function closeModal(id) { document.getElementById(id).classList.remove('open'); }

// ─── SAVE ───
function saveVehicle() {
  const name = document.getElementById('v-name').value.trim();
  const inspection = document.getElementById('v-inspection').value;
  if (!name || !inspection) { alert('車両名と車検日は必須です'); return; }
  const editId = document.getElementById('vehicle-edit-id').value;
  const data = {
    name, plate: document.getElementById('v-plate').value.trim(),
    maker: document.getElementById('v-maker').value.trim(),
    year: parseInt(document.getElementById('v-year').value)||null,
    mileage: parseInt(document.getElementById('v-mileage').value)||null,
    inspection, notes: document.getElementById('v-notes').value.trim()
  };
  if (editId) {
    const idx = db.vehicles.findIndex(x=>x.id===editId);
    db.vehicles[idx] = { ...db.vehicles[idx], ...data };
  } else {
    db.vehicles.push({ id: uid(), ...data });
  }
  saveDB(); closeModal('modal-vehicle'); render();
}

function saveMaintenance() {
  const vehicleId = document.getElementById('m-vehicle').value;
  const date = document.getElementById('m-date').value;
  const desc = document.getElementById('m-desc').value.trim();
  if (!vehicleId || !date || !desc) { alert('車両・日付・作業内容は必須です'); return; }
  db.maintenance.push({
    id: uid(), vehicleId, date,
    type: document.getElementById('m-type').value,
    desc, mileage: parseInt(document.getElementById('m-mileage').value)||null,
    cost: parseInt(document.getElementById('m-cost').value)||null,
    worker: document.getElementById('m-worker').value.trim(),
    next: document.getElementById('m-next').value
  });
  saveDB(); closeModal('modal-maintenance'); render();
}

function saveParts() {
  const vehicleId = document.getElementById('p-vehicle').value;
  const date = document.getElementById('p-date').value;
  const name = document.getElementById('p-name').value.trim();
  if (!vehicleId || !date || !name) { alert('車両・日付・部品名は必須です'); return; }
  db.parts.push({
    id: uid(), vehicleId, date, name,
    number: document.getElementById('p-number').value.trim(),
    mileage: parseInt(document.getElementById('p-mileage').value)||null,
    nextMileage: parseInt(document.getElementById('p-next-mileage').value)||null,
    cost: parseInt(document.getElementById('p-cost').value)||null,
    notes: document.getElementById('p-notes').value.trim()
  });
  saveDB(); closeModal('modal-parts'); render();
}

// ─── DELETE ───
function deleteVehicle(id) {
  if (!confirm('この車両を削除しますか？関連する整備・部品記録も削除されます。')) return;
  db.vehicles = db.vehicles.filter(x=>x.id!==id);
  db.maintenance = db.maintenance.filter(x=>x.vehicleId!==id);
  db.parts = db.parts.filter(x=>x.vehicleId!==id);
  saveDB(); render();
}
function deleteMaintenance(id) {
  if (!confirm('この整備記録を削除しますか？')) return;
  db.maintenance = db.maintenance.filter(x=>x.id!==id);
  saveDB(); render();
}
function deletePart(id) {
  if (!confirm('この部品記録を削除しますか？')) return;
  db.parts = db.parts.filter(x=>x.id!==id);
  saveDB(); render();
}

// モーダル外クリックで閉じる
document.querySelectorAll('.modal-overlay').forEach(el => {
  el.addEventListener('click', e => { if (e.target === el) el.classList.remove('open'); });
});

// ─── INIT ───
loadDB();
render();
</script>
</body>
</html>
